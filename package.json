{
  "name": "@repo/workspace",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "e2e:stack": "node ./scripts/e2e-stack.mjs up --web",
    "e2e:stack:reset": "node ./scripts/e2e-stack.mjs reset",
    "e2e:stack:smoke": "node ./scripts/e2e-stack.mjs smoke",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "!apps/mobile",
    "packages/*",
    "modules/*",
    "packages/config/*"
  ]
}
