# Copie para `.env` na raiz do app frontend (não commite o `.env`).

# URL base da API (backend). Usada no cliente e no servidor.
# Desenvolvimento típico: http://localhost:3333
# Se omitido, o código usa fallback http://localhost:3333.
NEXT_PUBLIC_SERVER_URL=http://localhost:3333

# Secret do Auth.js / NextAuth (assinatura das sessões JWT). Obrigatório em produção.
# Gere um valor forte: openssl rand -base64 32
AUTH_SECRET=

# Fallbacks aceitos pelo código quando AUTH_SECRET não está definido (opcionais):
# NEXTAUTH_SECRET=
# BETTER_AUTH_SECRET=
